---
// Showcase — bestseller marquee con foto reali prodotto
// Immagini via API Midocean (build-time fetch)

const products = [
  { img: '/products/product-2279.jpg', name: 'Power bank 5000 mAh',         cat: 'tech',      moq: 'Da 100 pezzi' },
  { img: '/products/product-6451.jpg', name: 'Porta telefono in bambù',     cat: 'office',    moq: 'Da 100 pezzi' },
  { img: '/products/product-9963.jpg', name: 'Porta tè in vetro 850ml',     cat: 'drinkware', moq: 'Da 100 pezzi' },
  { img: '/products/product-2156.jpg', name: 'Set connettori 9 in 1',       cat: 'tech',      moq: 'Da 100 pezzi' },
];
---

<section class="bg-cream py-16 overflow-hidden border-y border-ink/10">
  <div class="max-w-7xl mx-auto px-6 mb-8 flex items-center gap-3">
    <span class="w-8 h-px bg-ink"></span>
    <span class="eyebrow text-ink/70">i bestseller</span>
  </div>
  <div class="relative">
    <div class="flex gap-6 marquee-track-fast whitespace-nowrap">
      {[0, 1].map(set => (
        <div class="flex gap-6" aria-hidden={set === 1 ? 'true' : 'false'}>
          {products.map((p, i) => (
            <div class="showcase-card bg-cream rounded-2xl overflow-hidden border border-ink/10 hover:shadow-2xl transition min-w-[260px]">
              <div class="overflow-hidden bg-white" style="aspect-ratio:1/1;">
                <img
                  src={p.img}
                  alt={p.name}
                  class="w-full h-full object-contain p-4 hover:scale-105 transition duration-500"
                  loading={set === 0 && i < 2 ? 'eager' : 'lazy'}
                  width="260"
                  height="260"
                />
              </div>
              <div class="p-4">
                <div class="font-display text-base text-ink mb-0.5">{p.name}</div>
                <div class="text-sm text-ink/50">{p.cat} · {p.moq}</div>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
