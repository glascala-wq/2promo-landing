---
// Showcase — bestseller marquee con foto reali prodotto
// Immagini via API Midocean (build-time fetch)

const products = [
  { img: '/products/product-9963.jpg', name: 'T-shirt cotone 180g',    cat: 'textile',   moq: 'Da 50 pezzi', hasImg: true },
  { img: '/products/product-6451.jpg', name: 'Borraccia inox 500ml',   cat: 'drinkware', moq: 'Da 100 pezzi', hasImg: true },
  { img: '/products/product-2279.jpg', name: 'Power bank ecologico',   cat: 'tech',      moq: 'Da 100 pezzi', hasImg: true },
  { img: '/products/product-2156.jpg', name: 'Cappellino baseball',    cat: 'lifestyle', moq: 'Da 100 pezzi', hasImg: true },
  { img: null,                         name: 'Zaino tech 15"',          cat: 'lifestyle', moq: 'Da 50 pezzi',  hasImg: false },
  { img: null,                         name: 'Tazza ceramica 350ml',   cat: 'drinkware', moq: 'Da 100 pezzi', hasImg: false },
];

const gradients = [
  'background: linear-gradient(135deg, #1C1F2A 0%, #292929 100%)',
  'background: linear-gradient(135deg, #FE5000 0%, #c63f00 100%)',
];
---

<section class="bg-cream py-16 overflow-hidden border-y border-ink/10">
  <div class="max-w-7xl mx-auto px-6 mb-8 flex items-center gap-3">
    <span class="w-8 h-px bg-ink"></span>
    <span class="eyebrow text-ink/70">i bestseller</span>
  </div>
  <div class="relative">
    <div class="flex gap-6 marquee-track-fast whitespace-nowrap">
      {[0, 1].map(set => (
        <div class={`flex gap-6${set === 1 ? '' : ''}`} aria-hidden={set === 1 ? 'true' : 'false'}>
          {products.map((p, i) => (
            <div class="showcase-card bg-cream rounded-2xl overflow-hidden border border-ink/10 hover:shadow-2xl transition min-w-[260px]">
              <div class="overflow-hidden bg-cream" style="aspect-ratio:1/1;">
                {p.hasImg ? (
                  <img
                    src={p.img!}
                    alt={p.name}
                    class="w-full h-full object-cover hover:scale-105 transition duration-500"
                    loading={set === 0 && i < 2 ? 'eager' : 'lazy'}
                    width="260"
                    height="260"
                  />
                ) : (
                  <div class="w-full h-full flex items-end p-5 text-cream" style={gradients[i % 2]}>
                    <span class="font-display text-lg leading-tight">{p.name}</span>
                  </div>
                )}
              </div>
              <div class="p-4">
                <div class="font-display text-base text-ink mb-0.5">{p.name}</div>
                <div class="text-sm text-ink/50">{p.cat} · {p.moq}</div>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
