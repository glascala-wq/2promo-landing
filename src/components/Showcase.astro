---
// Showcase — horizontal marquee of bestseller product cards
---

<section class="bg-cream py-16 overflow-hidden border-y border-ink/10">
  <div class="max-w-7xl mx-auto px-6 mb-8 flex items-center gap-3">
    <span class="w-8 h-px bg-ink"></span>
    <span class="eyebrow text-ink/70">i bestseller</span>
  </div>
  <div class="relative">
    <div class="flex gap-6 marquee-track-fast whitespace-nowrap">
      <div class="flex gap-6">
        <div class="bg-orange/10 border border-orange/30 rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl text-ink">Power bank 5000 mAh</div>
          <div class="text-sm text-ink/60 mt-1">tech · 3.40€/pz · MOQ 100</div>
        </div>
        <div class="bg-navy text-cream rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl">T-shirt cotone 180g</div>
          <div class="text-sm opacity-70 mt-1">textile · 1.90€/pz · MOQ 50</div>
        </div>
        <div class="bg-cream border-2 border-ink/15 rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl text-ink">Borraccia inox 500ml</div>
          <div class="text-sm text-ink/60 mt-1">drinkware · 4.10€/pz · MOQ 100</div>
        </div>
        <div class="bg-orange-pale rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl text-ink">Tazza ceramica 350ml</div>
          <div class="text-sm text-ink/60 mt-1">drinkware · 1.20€/pz · MOQ 100</div>
        </div>
        <div class="bg-ink text-cream rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl">Zaino tech 15"</div>
          <div class="text-sm opacity-70 mt-1">lifestyle · 12.40€/pz · MOQ 50</div>
        </div>
        <div class="bg-orange text-cream rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl">Cappellino baseball</div>
          <div class="text-sm opacity-90 mt-1">lifestyle · 2.90€/pz · MOQ 100</div>
        </div>
      </div>
      <!-- Duplicate for seamless loop -->
      <div class="flex gap-6" aria-hidden="true">
        <div class="bg-orange/10 border border-orange/30 rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl text-ink">Power bank 5000 mAh</div>
          <div class="text-sm text-ink/60 mt-1">tech · 3.40€/pz · MOQ 100</div>
        </div>
        <div class="bg-navy text-cream rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl">T-shirt cotone 180g</div>
          <div class="text-sm opacity-70 mt-1">textile · 1.90€/pz · MOQ 50</div>
        </div>
        <div class="bg-cream border-2 border-ink/15 rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl text-ink">Borraccia inox 500ml</div>
          <div class="text-sm text-ink/60 mt-1">drinkware · 4.10€/pz · MOQ 100</div>
        </div>
        <div class="bg-orange-pale rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl text-ink">Tazza ceramica 350ml</div>
          <div class="text-sm text-ink/60 mt-1">drinkware · 1.20€/pz · MOQ 100</div>
        </div>
        <div class="bg-ink text-cream rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl">Zaino tech 15"</div>
          <div class="text-sm opacity-70 mt-1">lifestyle · 12.40€/pz · MOQ 50</div>
        </div>
        <div class="bg-orange text-cream rounded-2xl px-6 py-5 min-w-[260px]">
          <div class="font-display text-xl">Cappellino baseball</div>
          <div class="text-sm opacity-90 mt-1">lifestyle · 2.90€/pz · MOQ 100</div>
        </div>
      </div>
    </div>
  </div>
</section>
