---
// UrgencyBar — barra superiore fissa
// ⚠️ NO "24h" per policy brand (memory.md 12 mag 2026)
---
<div class="bg-ink text-cream text-[12px] tracking-wide">
  <div class="max-w-7xl mx-auto px-6 py-2 flex flex-wrap items-center justify-center gap-x-8 gap-y-1">
    <span class="flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-orange animate-pulse"></span>
      Spedizione rapida
    </span>
    <span class="opacity-40">·</span>
    <span>Bozza pre-stampa gratuita</span>
    <span class="opacity-40">·</span>
    <span class="flex items-center gap-2">
      <strong class="text-orange font-bold">30.000+</strong> articoli pronti per il vostro logo
    </span>
    <span class="opacity-40 hidden md:inline">·</span>
    <span class="hidden md:inline">Risposta <strong class="text-orange font-bold">rapida</strong></span>
  </div>
</div>
