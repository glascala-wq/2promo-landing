---
// CasiReali — griglia foto lavori reali
const photos = [
  { src: '/casestudy/felpa-corporate.webp',     alt: 'Felpa aziendale ricamata',       eager: true },
  { src: '/casestudy/vetrofania-retail.webp',   alt: 'Vetrofania per punto vendita',   eager: true },
  { src: '/casestudy/tshirt-sport.webp',        alt: 'T-shirt sportiva stampata',      eager: true },
  { src: '/casestudy/cappellino-ricamato.webp', alt: 'Cappellino ricamato',            eager: true },
  { src: '/casestudy/sacca-coulisse.webp',      alt: 'Sacca coulisse personalizzata',  eager: false },
  { src: '/casestudy/divisa-sport.webp',        alt: 'Divisa sportiva personalizzata', eager: false },
  { src: '/casestudy/borraccia-termica.webp',   alt: 'Borraccia termica in acciaio',   eager: false },
  { src: '/casestudy/totem-evento.webp',        alt: 'Totem espositivo brandizzato',   eager: false },
  { src: '/casestudy/gadget-evento.webp',       alt: 'Gadget per evento',              eager: false },
  { src: '/casestudy/tazza-corporate.webp',     alt: 'Tazza personalizzata',           eager: false },
  { src: '/casestudy/bermuda-lavoro.webp',      alt: 'Bermuda da lavoro brandizzato',  eager: false },
  { src: '/casestudy/banner-sponsorship.webp',  alt: 'Banner sponsorizzazione evento', eager: false },
];
---

<section id="casi-reali" class="bg-cream py-20 md:py-24 border-t border-ink/10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6" data-reveal>
      <span class="w-8 h-px bg-ink"></span>
      <span class="eyebrow text-ink/70">— lavori veri</span>
    </div>
    <div class="flex items-end justify-between flex-wrap gap-6 mb-10" data-reveal>
      <h2 class="font-display-tight text-5xl md:text-7xl text-ink leading-[0.9]">
        Cosa abbiamo<br>stampato di recente.
      </h2>
      <p class="text-ink/70 text-lg max-w-md">
        Lavori finiti per i brand che ci scelgono. Prodotti veri, stampe vere, clienti veri.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
      {photos.map((p) => (
        <figure class="overflow-hidden rounded-2xl bg-ink/5 m-0" style="aspect-ratio:3/4;">
          <img
            src={p.src}
            alt={p.alt}
            loading={p.eager ? 'eager' : 'lazy'}
            class="w-full h-full object-cover hover:scale-105 transition duration-500"
            width="900"
            height="1200"
          />
        </figure>
      ))}
    </div>

    <p class="text-center mt-10 text-ink/60 text-sm">
      Tra i nostri clienti: Red Bull, MediaWorld, Monge, Radio Italia, Prato Nevoso e tanti altri.
      <a href="#preventivo" class="text-orange font-bold hover:underline ml-1">Chiedeteci una proposta →</a>
    </p>
  </div>
</section>
