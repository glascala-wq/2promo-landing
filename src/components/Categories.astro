---
// Categories — asymmetric 6-card grid
---
<section class="bg-cream pb-24 md:pb-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6" data-reveal>
      <span class="w-8 h-px bg-ink"></span>
      <span class="eyebrow text-ink/70">— cosa stampiamo</span>
    </div>
    <div class="flex items-end justify-between flex-wrap gap-6 mb-14">
      <h2 class="font-display-tight text-6xl md:text-8xl text-ink leading-[0.9]" data-reveal>
        Tutto.<br><span class="text-orange">Davvero tutto.</span>
      </h2>
      <p class="text-ink/70 text-lg max-w-md" data-reveal>
        Otto macro-categorie, trenta sotto-categorie, migliaia di prodotti. Sotto trovate la versione corta.
      </p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 grid-rows-3 md:grid-rows-2 gap-4 md:gap-5 auto-rows-[180px] md:auto-rows-[260px]">
      <!-- TEXTILE — hero card (col-span-2 row-span-2) -->
      <a
        href="/catalogo"
        class="cat-card relative col-span-2 row-span-2 rounded-3xl overflow-hidden p-6 md:p-8 flex flex-col justify-between"
        style="background: linear-gradient(135deg, #FE5000 0%, #FFB371 100%); text-decoration:none;"
        data-reveal
      >
        <span class="eyebrow text-cream/80">01 · TEXTILE</span>
        <div>
          <h3 class="font-display-tight text-cream text-5xl md:text-7xl leading-[0.9]">T-shirt,<br>polo,<br>felpe.</h3>
          <p class="cat-tag text-cream/90 mt-4 text-sm font-bold">→ 6.200+ articoli</p>
        </div>
      </a>
      <!-- DRINKWARE -->
      <a
        href="/catalogo"
        class="cat-card relative rounded-3xl overflow-hidden p-5 flex flex-col justify-between bg-navy text-cream"
        data-reveal
        style="text-decoration:none;"
      >
        <span class="eyebrow text-cream/60">02 · DRINKWARE</span>
        <div>
          <h3 class="font-display-tight text-3xl md:text-4xl leading-tight">Tazze, borracce, thermos.</h3>
          <p class="cat-tag text-cream/70 mt-2 text-xs font-bold">→ 4.100+ articoli</p>
        </div>
      </a>
      <!-- TECH -->
      <a
        href="/catalogo"
        class="cat-card relative rounded-3xl overflow-hidden p-5 flex flex-col justify-between bg-cream text-ink border-2 border-ink/10"
        data-reveal
        style="text-decoration:none;"
      >
        <span class="eyebrow text-ink/60">03 · TECH</span>
        <div>
          <h3 class="font-display-tight text-3xl md:text-4xl leading-tight">USB, power bank, cuffie.</h3>
          <p class="cat-tag text-ink/60 mt-2 text-xs font-bold">→ 3.800+ articoli</p>
        </div>
      </a>
      <!-- ECO -->
      <a
        href="/catalogo"
        class="cat-card relative rounded-3xl overflow-hidden p-5 flex flex-col justify-between text-cream"
        style="background: linear-gradient(160deg, #1C1F2A 0%, #292929 100%); text-decoration:none;"
        data-reveal
      >
        <span class="eyebrow text-orange">04 · ECO</span>
        <div>
          <h3 class="font-display-tight text-3xl md:text-4xl leading-tight">RPET, bambù, cotone bio.</h3>
          <p class="cat-tag text-cream/70 mt-2 text-xs font-bold">→ 2.900+ articoli</p>
        </div>
      </a>
      <!-- OFFICE -->
      <a
        href="/catalogo"
        class="cat-card relative rounded-3xl overflow-hidden p-5 flex flex-col justify-between bg-orange-pale text-ink"
        data-reveal
        style="text-decoration:none;"
      >
        <span class="eyebrow text-ink/60">05 · OFFICE</span>
        <div>
          <h3 class="font-display-tight text-3xl md:text-4xl leading-tight">Penne, taccuini, agende.</h3>
          <p class="cat-tag text-ink/60 mt-2 text-xs font-bold">→ 4.600+ articoli</p>
        </div>
      </a>
      <!-- LIFESTYLE -->
      <a
        href="/catalogo"
        class="cat-card relative rounded-3xl overflow-hidden p-5 flex flex-col justify-between bg-ink text-cream"
        data-reveal
        style="text-decoration:none;"
      >
        <span class="eyebrow text-cream/60">06 · LIFESTYLE</span>
        <div>
          <h3 class="font-display-tight text-3xl md:text-4xl leading-tight">Zaini, ombrelli, cappellini.</h3>
          <p class="cat-tag text-cream/70 mt-2 text-xs font-bold">→ 5.400+ articoli</p>
        </div>
      </a>
    </div>
    <div class="mt-10 flex flex-wrap items-center justify-between gap-6">
      <p class="font-display-tight text-2xl md:text-3xl text-ink leading-tight max-w-md">
        …e altre 22 categorie. <span class="text-ink/50">Sì, abbiamo contato.</span>
      </p>
      <a
        href="/catalogo"
        class="border-2 border-ink text-ink px-7 py-4 text-sm font-bold tracking-wide rounded-full hover:bg-ink hover:text-cream transition"
        style="text-decoration:none;"
      >
        Sfoglia il catalogo completo →
      </a>
    </div>
  </div>
</section>
